{
  "name": "@dinorip/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "pnpm build:electron && concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && env -u ELECTRON_RUN_AS_NODE cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "pnpm build:electron && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "lint": "eslint electron src --ext .ts,.tsx",
    "pack": "pnpm build && electron-builder --dir",
    "dist": "pnpm build && electron-builder"
  },
  "dependencies": {
    "@dinorip/core": "workspace:*",
    "@dinorip/ipc-contracts": "workspace:*",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.2"
  },
  "build": {
    "appId": "app.dinorip.desktop",
    "productName": "DinoRip",
    "executableName": "dinorip",
    "electronVersion": "36.9.5",
    "publish": [
      {
        "provider": "github",
        "owner": "maria-rcks",
        "repo": "dinorip"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/sharp/**",
      "**/node_modules/@img/**"
    ],
    "extraResources": [
      {
        "from": "build/icon-rounded.png",
        "to": "icon-rounded.png"
      }
    ],
    "afterPack": "build/afterPackIcon.cjs",
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.graphics-design",
      "icon": "build/icon.png"
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Graphics",
      "icon": "build/icon.png"
    }
  }
}
